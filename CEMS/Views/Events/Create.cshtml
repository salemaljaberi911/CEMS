@model CEMS.Models.Event

@{
    ViewData["Title"] = "Create New Event";
}

<div class="page-header">
    <h1 class="page-title">Create New Event</h1>
    <p class="page-subtitle">
        Submit a new campus event for review. Newly created events will be marked as pending until approved by a staff coordinator.
    </p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-8">
        <div class="form-card">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <div class="mb-4">
                    <h4 class="mb-1">Event Information</h4>
                    <p class="subtle-text mb-0">
                        Provide the core details for your event submission.
                    </p>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Event Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Enter the event title" />
                    <div class="subtle-text mt-1">Choose a clear and professional event title.</div>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" placeholder="Provide a clear description of the event"></textarea>
                    <div class="subtle-text mt-1">
                        Include the purpose of the event, target audience, and any important activity details.
                    </div>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="EventDate" class="form-label">Event Date &amp; Time</label>
                        <input asp-for="EventDate" type="datetime-local" class="form-control" />
                        <div class="subtle-text mt-1">Select the planned event schedule.</div>
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="Enter event location" />
                        <div class="subtle-text mt-1">Use a clear venue, room, or campus location.</div>
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Capacity" class="form-label">Capacity</label>
                    <input asp-for="Capacity" class="form-control" placeholder="Enter maximum number of participants" />
                    <div class="subtle-text mt-1">Set the maximum number of registrations allowed for this event.</div>
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <div class="mt-3 mb-4">
                    <label class="form-label">Event Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    <div class="subtle-text mt-1">
                        Upload an optional event image to make the event more attractive.
                    </div>
                </div>

                <div class="content-card mb-4">
                    <h5 class="mb-2">Submission Note</h5>
                    <p class="subtle-text mb-0">
                        After submission, your event will remain in <strong>Pending</strong> status until it is reviewed by a staff coordinator.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">
                        Create Event
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back to My Events
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="content-card h-100">
            <h4 class="mb-3">Before You Submit</h4>

            <div class="border-soft rounded-soft p-3 bg-white mb-3">
                <div class="data-label mb-1">Approval Workflow</div>
                <div class="subtle-text">
                    Every new event must be reviewed before it becomes visible to students.
                </div>
            </div>

            <div class="border-soft rounded-soft p-3 bg-white mb-3">
                <div class="data-label mb-1">Capacity Planning</div>
                <div class="subtle-text">
                    Make sure your capacity reflects the real number of participants your event can support.
                </div>
            </div>

            <div class="border-soft rounded-soft p-3 bg-white">
                <div class="data-label mb-1">Professional Submission</div>
                <div class="subtle-text">
                    Clear titles, accurate dates, detailed descriptions, and a good event image improve approval quality and visibility.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}