@model CEMS.Models.Event

@{
    ViewData["Title"] = "Edit Event";
}

<div class="page-header">
    <h1 class="page-title">Edit Event</h1>
    <p class="page-subtitle">
        Update the event details, review the event information, and save your changes.
    </p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-8">
        <div class="form-card">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <h4 class="mb-1">Event Information</h4>
                    <p class="subtle-text mb-0">
                        Update the details below and save your changes when everything is accurate.
                    </p>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Event Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Enter the event title" />
                    <div class="subtle-text mt-1">Use a title that clearly describes the event.</div>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" placeholder="Provide a clear description of the event"></textarea>
                    <div class="subtle-text mt-1">
                        Keep the description informative, accurate, and aligned with the actual event plan.
                    </div>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="EventDate" class="form-label">Event Date &amp; Time</label>
                        <input asp-for="EventDate"
                               type="datetime-local"
                               class="form-control"
                               value="@Model.EventDate.ToString("yyyy-MM-ddTHH:mm")" />
                        <div class="subtle-text mt-1">Adjust the schedule if the event timing has changed.</div>
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="Enter event location" />
                        <div class="subtle-text mt-1">Keep the location clear and specific for participants.</div>
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Capacity" class="form-label">Capacity</label>
                    <input asp-for="Capacity" class="form-control" placeholder="Enter maximum number of participants" />
                    <div class="subtle-text mt-1">Update capacity carefully to reflect real event availability.</div>
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <div class="mt-3 mb-4">
                    <label class="form-label">Update Event Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    <div class="subtle-text mt-1">
                        Upload a new image only if you want to replace the current one.
                    </div>

                    @if (Model.ImageData != null && Model.ImageContentType != null)
                    {
                        var base64 = Convert.ToBase64String(Model.ImageData);
                        var imageSrc = $"data:{Model.ImageContentType};base64,{base64}";

                        <div class="mt-3">
                            <img src="@imageSrc"
                                 alt="Current event image"
                                 class="img-fluid rounded-soft border-soft"
                                 style="max-height: 240px; object-fit: cover;" />
                        </div>
                    }
                </div>

                <div class="content-card mb-4">
                    <h5 class="mb-2">Update Note</h5>
                    <p class="subtle-text mb-0">
                        Make sure the event information is accurate before saving changes. Approval status is managed through the event workflow.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back to My Events
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="content-card h-100">
            <h4 class="mb-3">Editing Guidance</h4>

            <div class="border-soft rounded-soft p-3 bg-white mb-3">
                <div class="data-label mb-1">Review Accuracy</div>
                <div class="subtle-text">
                    Confirm the title, date, and location before saving to avoid confusion for participants and staff.
                </div>
            </div>

            <div class="border-soft rounded-soft p-3 bg-white mb-3">
                <div class="data-label mb-1">Workflow Awareness</div>
                <div class="subtle-text">
                    Event status remains controlled by the approval workflow and should not be changed directly here.
                </div>
            </div>

            <div class="border-soft rounded-soft p-3 bg-white">
                <div class="data-label mb-1">Capacity Changes</div>
                <div class="subtle-text">
                    Adjusting the capacity affects how many participants can register, so update it carefully.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}