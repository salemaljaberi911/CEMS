@model CEMS.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="page-header">
    <h1 class="page-title">Delete Event</h1>
    <p class="page-subtitle">
        Review the event information carefully before permanently removing it from your organizer workspace.
    </p>
</div>

<div class="alert alert-danger mb-4">
    <strong>Warning:</strong> This action will permanently remove the selected event. This operation cannot be undone.
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h2 class="mb-2">@Model.Title</h2>
                    <p class="subtle-text mb-0">
                        Please confirm that you want to delete this event and all associated organizer-side visibility for it.
                    </p>
                </div>

                <div>
                    @if (Model.Status == "Pending")
                    {
                        <span class="badge badge-status badge-pending">Pending</span>
                    }
                    else if (Model.Status == "Approved")
                    {
                        <span class="badge badge-status badge-approved">Approved</span>
                    }
                    else if (Model.Status == "Rejected")
                    {
                        <span class="badge badge-status badge-rejected">Rejected</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.Status</span>
                    }
                </div>
            </div>

            <hr />

            <div class="mb-4">
                <h5 class="mb-2">Description</h5>
                <p class="mb-0 subtle-text">@Model.Description</p>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="border-soft rounded-soft p-3 h-100 bg-white">
                        <div class="data-label mb-1">Event Date</div>
                        <div class="data-value">@Model.EventDate.ToString("dddd, MMM dd, yyyy - hh:mm tt")</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border-soft rounded-soft p-3 h-100 bg-white">
                        <div class="data-label mb-1">Location</div>
                        <div class="data-value">@Model.Location</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border-soft rounded-soft p-3 h-100 bg-white">
                        <div class="data-label mb-1">Capacity</div>
                        <div class="stat-number">@Model.Capacity</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border-soft rounded-soft p-3 h-100 bg-white">
                        <div class="data-label mb-1">Current Status</div>
                        <div class="mt-2">
                            @if (Model.Status == "Pending")
                            {
                                <span class="badge badge-status badge-pending">Pending</span>
                            }
                            else if (Model.Status == "Approved")
                            {
                                <span class="badge badge-status badge-approved">Approved</span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge badge-status badge-rejected">Rejected</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Status</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="content-card h-100">
            <h4 class="mb-3 text-danger">Confirm Deletion</h4>

            <p class="subtle-text">
                Deleting this event will remove it from your organizer records. Make sure this action is intended before proceeding.
            </p>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger" data-confirm="Are you sure you want to permanently delete this event?">
                        Delete Event
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel and Return
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>