@model IEnumerable<CEMS.Models.ViewModels.MyRegistrationViewModel>

@{
    ViewData["Title"] = "My Registrations";
}

<div class="page-header">
    <h1 class="page-title">My Registrations</h1>
    <p class="page-subtitle">
        Review the events you have registered for and manage your registrations when needed.
    </p>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info mb-4">
        @TempData["Message"]
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <h5>No registrations found</h5>
        <p>You have not registered for any events yet. Browse approved events to get started.</p>

        <div class="mt-3">
            <a asp-controller="Events" asp-action="ApprovedEvents" class="btn btn-primary">
                Browse Approved Events
            </a>
        </div>
    </div>
}
else
{
    <div class="content-card">
        <div class="row g-3 mb-3">
            <div class="col-md-8">
                <input type="text"
                       class="form-control"
                       placeholder="Search my registrations..."
                       data-table-search="myRegistrationsTable" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle" id="myRegistrationsTable">
                <thead>
                <tr>
                    <th>Event Title</th>
                    <th>Event Date</th>
                    <th>Location</th>
                    <th>Registered At</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Title</strong>
                        </td>
                        <td>@item.EventDate.ToString("ddd, MMM dd, yyyy - hh:mm tt")</td>
                        <td>@item.Location</td>
                        <td>@item.RegisteredAt.ToString("ddd, MMM dd, yyyy - hh:mm tt")</td>
                        <td class="text-end">
                            <form asp-action="CancelRegistration" asp-route-id="@item.RegistrationId" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-danger btn-sm"
                                        data-confirm="Are you sure you want to cancel this registration?">
                                    Cancel Registration
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}